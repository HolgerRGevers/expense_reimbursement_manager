 * Version      : 1.0
 */
 application "Expense Reimbursement Management"
 {
 	date format = "dd-MMM-yyyy"
 	time zone = "Africa/Johannesburg"
 	time format = "24-hr"

 	forms
	{
		form approval_history
		{
			displayname = "Approval History"
			success message = "Approval History Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			claim
			(
				type = list	
				displayname = "Claim"
				values  = expense_claims.ID
    			displayformat = [claim_id]
				allow new entries
				[
					displayname = "Add New"
				]
				sortorder = ascending
				height = 13px
				description
				[
					type = help_text
					message = "The expense claim this audit record relates to."
				]
	 			row = 1
	 			column = 1   
				width = medium
			)
			action_1
			(
				type = picklist
				displayname = "Action"
				values = {"Submitted","Approved (LM)","Approved (HoD)","Rejected","Escalated (SLA Breach)","Resubmitted"}
				description
				[
					type = help_text
					message = "The action taken: Submitted, Approved (LM/HoD), Rejected, Escalated, or Resubmitted."
				]
	 			row = 1
	 			column = 1   
				width = medium
			)
			actor
			(
    			type = text
				displayname = "Actor"
				description
				[
					type = help_text
					message = "The person or system that performed the action."
				]
	 			row = 1
	 			column = 1   
				width = medium
			)
			timestamp
			(
    			type = datetime
				displayname = "Timestamp"
				timedisplayoptions = "hh:mm:ss"
				alloweddays = 0,1,2,3,4,5,6
				description
				[
					type = help_text
					message = "Date and time the action was recorded."
				]
	 			row = 1
	 			column = 1   
				width = medium
			)
			comments
			(
    			type = textarea
				displayname = "Comments"
				height = 100px
				description
				[
					type = help_text
					message = "Details about the action, including amounts, GL codes, or rejection reasons."
				]
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
		form approval_thresholds
		{
			displayname = "Approval Thresholds"
			success message = "Approval Threshold Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			tier_name
			(
    			type = text
				displayname = "Tier Name"
				description
				[
					type = help_text
					message = "Name of the approval tier (e.g., Tier 1 - Line Manager)."
				]
	 			row = 1
	 			column = 1   
				width = medium
			)
			max_amount_zar
			(
				displayname = "Max Amount ZAR"
				type = ZAR
				description
				[
					type = help_text
					message = "Maximum claim amount (ZAR) this tier can approve. Claims above this escalate to the next tier."
				]
	 			row = 1
	 			column = 1   
				width = medium
			)
			approver_role
			(
    			type = text
				displayname = "Approver Role"
				description
				[
					type = help_text
					message = "The Zoho Creator role that approves claims at this tier."
				]
	 			row = 1
	 			column = 1
				width = medium
			)
			Active
			(
    			type = checkbox
				initial value = true
				description
				[
					type = help_text
					message = "Whether this threshold tier is currently active in the approval workflow."
				]
	 			row = 1
	 			column = 1
				width = medium
			)
			Tier_Order
			(
				type = number
				displayname = "Tier Order"
				initial value = 0
				description
				[
					type = help_text
					message = "Numeric order of this tier in the escalation chain. Lower numbers approve first."
				]
	 			row = 1
	 			column = 1
				width = medium
			)

			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
		form clients
		{
			displayname = "Clients"
			success message = "Client Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			client_id
			(
    			type = autonumber
				displayname = "Client ID"
				start index = 1
				description
				[
					type = help_text
					message = "Auto-generated client identifier."
				]
	 			row = 1
	 			column = 1   
				width = medium
			)
			name
			(
    			type = text
				displayname = "Name"
				description
				[
					type = help_text
					message = "Client name as it appears in dropdown selections."
				]
	 			row = 1
	 			column = 1   
				width = medium
			)
			is_active
			(
    			type = checkbox
				displayname = "Active"
				initial value = true
				description
				[
					type = help_text
					message = "Whether this client is currently active and available for selection."
				]
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
		form departments
		{
			displayname = "Departments"
			success message = "Department Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			department_id
			(
    			type = autonumber
				displayname = "Department ID"
				start index = 1
				description
				[
					type = help_text
					message = "Auto-generated department identifier."
				]
	 			row = 1
	 			column = 1   
				width = medium
			)
			name
			(
    			type = text
				displayname = "Name"
				description
				[
					type = help_text
					message = "Department name as it appears in dropdown selections."
				]
	 			row = 1
	 			column = 1   
				width = medium
			)
			is_active
			(
    			type = checkbox
				displayname = "Active"
				initial value = true
				description
				[
					type = help_text
					message = "Whether this department is currently active and available for selection."
				]
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
		form expense_claims
		{
			displayname = "Expense Claims"
			success message = "Expense Claim Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			must have Employee_Name1
			(
    			type = name
				displayname = "Employee Name"
     			prefix
     			(
	     			 type = prefix
	     			 displayname ="Prefix"
	     			 visibility = false
	     			 value = {"Mr.","Mrs.","Ms."}
     			) 
     			first_name
     			(
	     			 type = first_name
	     			 displayname ="First Name"
     			) 
     			last_name
     			(
	     			 type = last_name
	     			 displayname ="Last Name"
     			) 
     			suffix
     			(
	     			 type = suffix
	     			 displayname ="Suffix"
	     			 visibility = false
     			) 
				description
				[
					type = help_text
					message = "Your full name as registered in the system. Auto-populated on form load."
				]
	 			row = 1
	 			column = 1   
				width = medium
				personal data = true
			)
			must have Email
			(
    			type = picklist
				module = users
				displayformat = [emailid]
    			description
    			[
    				type = help_text
    			 	message = "Notification routing target."
    			]
	 			row = 1
	 			column = 1   
				width = medium
				personal data = true
			)
			must have Submission_Date
			(
    			type = datetime
				displayname = "Submission Date"
				timedisplayoptions = "hh:mm:ss"
				alloweddays = 0,1,2,3,4,5,6
				description
				[
					type = help_text
					message = "Date and time the claim was submitted. Set automatically."
				]
	 			row = 1
	 			column = 1   
				width = medium
			)
			claim_id
			(
    			type = autonumber
				displayname = "Claim ID"
				start index = 1
				description
				[
					type = help_text
					message = "System-generated unique claim number. Used for tracking and reference."
				]
	 			row = 1
	 			column = 1   
				width = medium
			)
			department
			(
				type = list	
				displayname = "Department"
				values  = departments.ID
    			displayformat = [" - " + name]
				sortorder = ascending
				height = 60px
				description
				[
					type = help_text
					message = "Select your department. Used for reporting and approval routing."
				]
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Claim_Reference
			(
    			type = text
				displayname = "Claim Reference"
				description
				[
					type = help_text
					message = "Auto-generated reference (EXP-0001 format). Use this when communicating about the claim."
				]
	 			row = 1
	 			column = 1   
				width = medium
			)
			client
			(
				type = list	
				displayname = "Client"
				values  = clients.ID
    			displayformat = [" - " + name]
				sortorder = ascending
				height = 60px
				description
				[
					type = help_text
					message = "Select the client this expense relates to. Choose Internal for non-client expenses."
				]
	 			row = 1
	 			column = 1   
				width = medium
			)
			Expense_Date
			(
    			type = date
				displayname = "Expense Date"
				alloweddays = 0,1,2,3,4,5,6
				description
				[
					type = help_text
					message = "Date the expense was incurred. Cannot be in the future or older than 90 days."
				]
	 			row = 1
	 			column = 1   
				width = medium
			)
			Department_Shadow
			(
    			type = text
				displayname = "Department Shadow"
				private = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			category
			(
				type = picklist
				displayname = "Category"
				values = {"Travel","Accommodation","Meals & Entertainment","Office Supplies","Communication","Professional Services","Other"}
				description
				[
					type = help_text
					message = "Select the expense category. Determines GL code mapping and VAT requirements."
				]
	 			row = 1
	 			column = 1   
				width = medium
			)
			Client_Shadow
			(
    			type = text
				displayname = "Client Shadow"
				private = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			amount_zar
			(
				displayname = "Amount ZAR"
				type = ZAR
				description
				[
					type = help_text
					message = "Total expense amount in South African Rand (ZAR). Must be greater than zero."
				]
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Supporting_Documents
			(
    			type = upload file
				displayname = "Supporting Documents"
    			file count = 10
				browse = local_drive, google_docs, zoho_docs
				description
				[
					type = help_text
					message = "Upload receipts or invoices. Required by SARS S11(a) for all claims. Max 10 files."
				]
	 			row = 1
	 			column = 1   
				width = medium
			)
			description
			(
    			type = textarea
				displayname = "Description"
				height = 100px
				description
				[
					type = help_text
					message = "Describe the business purpose of this expense. Required for SARS S11(a) substantiation."
				]
	 			row = 1
	 			column = 1
				width = medium
			)
			VAT_Invoice_Type
			(
				type = picklist
				displayname = "VAT Invoice Type"
				values = {"None","Abbreviated (< R5,000)","Full Tax Invoice (>= R5,000)"}
				description
				[
					type = help_text
					message = "Select invoice type. Claims >= R5,000 require a Full Tax Invoice per SARS VAT rules."
				]
	 			row = 1
	 			column = 1
				width = medium
			)
			POPIA_Consent
			(
    			type = checkbox
				displayname = "POPIA Consent"
    			description
    			[
    				type = help_text
    			 	message = "I consent to the processing of my personal data for expense reimbursement purposes in accordance with POPIA."
    			]
				initial value = false
	 			row = 1
	 			column = 1
				width = medium
			)
			status
			(
				type = picklist
				displayname = "Status"
				values = {"Draft","Submitted","Pending LM Approval","Pending HoD Approval","Approved","Rejected","Resubmitted"}
				description
				[
					type = help_text
					message = "Current claim status. Updated automatically by the approval workflow."
				]
	 			row = 1
	 			column = 1   
				width = medium
			)
			Rejection_Reason
			(
    			type = textarea
				displayname = "Rejection Reason"
				height = 100px
				description
				[
					type = help_text
					message = "Reason for rejection, provided by the approver. Read-only for employees."
				]
	 			row = 1
	 			column = 1   
				width = medium
			)
			Version
			(
				type = number
				initial value = 1
				description
				[
					type = help_text
					message = "Claim version number. Incremented each time the claim is resubmitted after rejection."
				]
	 			row = 1
	 			column = 1
				width = medium
			)
			Retention_Expiry_Date
			(
    			type = date
				displayname = "Retention Expiry Date"
    			description
    			[
    				type = help_text
    			 	message = "SARS Tax Administration Act S29: 5-year retention from submission date."
    			]
				alloweddays = 0,1,2,3,4,5,6
				private = true
	 			row = 1
	 			column = 1
				width = medium
			)
			Parent_Claim_ID
			(
				type = picklist	
				displayname = "Parent Claim ID"
				values  = expense_claims.ID
    			displayformat = [claim_id]
				sortorder = ascending
				private = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			gl_code
			(
				type = list	
				displayname = "GL Code"
				values  = gl_accounts.ID
    			displayformat = [gl_code]
				sortorder = ascending
				height = 13px
				description
				[
					type = help_text
					message = "General Ledger code assigned during approval. Maps the expense to the correct account."
				]
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
		form gl_accounts
		{
			displayname = "GL Accounts"
			success message = "Gl Account Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			gl_code
			(
    			type = text
				displayname = "GL Code"
				description
				[
					type = help_text
					message = "The General Ledger account code (e.g., 6200). Must match your accounting system."
				]
	 			row = 1
	 			column = 1   
				width = medium
			)
			account_name
			(
    			type = text
				displayname = "Account Name"
				description
				[
					type = help_text
					message = "Descriptive name for this GL account (e.g., Travel - Local Transport)."
				]
	 			row = 1
	 			column = 1   
				width = medium
			)
			expense_category
			(
				type = picklist
				displayname = "Expense Category"
				values = {"Travel","Accommodation","Meals & Entertainment","Office Supplies","Communication","Professional Services","Other"}
				description
				[
					type = help_text
					message = "The expense category this GL code maps to. Used for auto-assignment during approval."
				]
	 			row = 1
	 			column = 1   
				width = medium
			)
			receipt_required
			(
    			type = checkbox
				displayname = "Receipt Required"
				initial value = true
				description
				[
					type = help_text
					message = "Whether a receipt/invoice is required for expenses in this category. Default: Yes (SARS S11(a))."
				]
	 			row = 1
	 			column = 1   
				width = medium
			)
			SARS_Provision
			(
    			type = text
				displayname = "SARS Provision"
    			description
    			[
    				type = help_text
    			 	message = "Maps each GL code to SARS deduction provision, e.g. \"S11(a) + S8(1)(a)\". Used in compliance reporting."
    			]
	 			row = 1
	 			column = 1   
				width = medium
			)
			Risk_Level
			(
				type = picklist
				displayname = "Risk Level"
				values = {"Standard","Elevated","High"}
				initial value = "Standard"
    			description
    			[
    				type = help_text
    			 	message = "ISO 37001: Categories prone to bribery risk receive enhanced scrutiny."
    			]
	 			row = 1
	 			column = 1
				width = medium
			)
			Active
			(
    			type = checkbox
				initial value = true
				description
				[
					type = help_text
					message = "Whether this GL code is currently available for assignment."
				]
	 			row = 1
	 			column = 1
				width = medium
			)

			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
	}
	reports
	{
		list expense_claims_Report
		{
			displayName = "All Expense Claims"
			show all rows from expense_claims    
			(
				claim_id as "Claim ID"
				department as "Department"
				client as "Client"
				category as "Category"
				amount_zar as "Amount ZAR"
				(
					display = total,average,min,max	
				)
				description as "Description"
				status as "Status"
				gl_code as "GL Code"
			)
			conditional formatting
			(
				"New Formatting1"
				{
				condition = (category == "Entertainment")
				fields = [category]
				format = "color:#ffffff;background-color:#765f89;"
				}
				"New Formatting2"
				{
				condition = (category == "Meals")
				fields = [category]
				format = "color:#000000;background-color:#1bbc9b;"
				}
				"New Formatting3"
				{
				condition = (category == "Travel")
				fields = [category]
				format = "color:#ffffff;background-color:#e84c3d;"
				}
			)
		}
		list gl_accounts_Report
		{
			displayName = "All Gl Accounts"
			show all rows from gl_accounts    
			(
				gl_code as "GL Code"
				account_name as "Account Name"
				expense_category as "Expense Category"
				receipt_required as "Receipt Required"
			)
			conditional formatting
			(
				"New Formatting1"
				{
				condition = (expense_category == "Entertainment")
				fields = [expense_category]
				format = "color:#ffffff;background-color:#765f89;"
				}
				"New Formatting2"
				{
				condition = (expense_category == "Meals")
				fields = [expense_category]
				format = "color:#000000;background-color:#1bbc9b;"
				}
				"New Formatting3"
				{
				condition = (expense_category == "Supplies")
				fields = [expense_category]
				format = "color:#ffffff;background-color:#e84c3d;"
				}
			)
		}
		kanban gl_accounts_by_expense_category
		{
			displayName = "Expense Categories"
			show all rows from gl_accounts    
			(
				gl_code as "GL Code"
				account_name as "Account Name"
				expense_category as "Expense Category"
				receipt_required as "Receipt Required"
			)
			options
			(
	 			display field = expense_category
	 		)
		}
		list approval_history_Report
		{
			displayName = "All Approval Histories"
			show all rows from approval_history    
			(
				claim as "Claim"
				action_1 as "Action"
				actor as "Actor"
				timestamp as "Timestamp"
				comments as "Comments"
			)
			conditional formatting
			(
				"New Formatting1"
				{
				condition = (action_1 == "Approved")
				fields = [action_1]
				format = "color:#ffffff;background-color:#765f89;"
				}
				"New Formatting2"
				{
				condition = (action_1 == "Rejected")
				fields = [action_1]
				format = "color:#000000;background-color:#1bbc9b;"
				}
				"New Formatting3"
				{
				condition = (action_1 == "Submitted")
				fields = [action_1]
				format = "color:#ffffff;background-color:#e84c3d;"
				}
			)
		}
		list approval_thresholds_Report
		{
			displayName = "All Approval Thresholds"
			show all rows from approval_thresholds    
			(
				tier_name as "Tier Name"
				max_amount_zar as "Max Amount ZAR"
				(
					display = total,average,min,max	
				)
				approver_role as "Approver Role"
			)
		}
		list clients_Report
		{
			displayName = "All Clients"
			show all rows from clients    
			(
				client_id as "Client ID"
				name as "Name"
				is_active as "Active"
			)
		}
		list departments_Report
		{
			displayName = "All Departments"
			show all rows from departments    
			(
				department_id as "Department ID"
				name as "Name"
				is_active as "Active"
			)
		}
		list Audit_Trail
		{
			displayName = "Audit Trail"
			show all rows from approval_history    
			(
				claim as "Claim"
				(
					delimiter = comma
				)
				action_1 as "Action"
				actor as "Actor"
				timestamp as "Timestamp"
				comments as "Comments"
				claim.claim_id as "Claim ID"
			)
			sort by
			(
				timestamp ascending
			)
		}
		list pending_approvals_manager
		{
			displayName = "Pending Approvals Manager"
			show all rows from expense_claims  [status == "Pending LM Approval" || status == "Pending HoD Approval"]  
			(
				Employee_Name1  as "Employee Name"
	 			(
	      			displayformat = [first_name+""+prefix+""+last_name+""+suffix]
	 			)
				Email
				Submission_Date as "Submission Date"
				claim_id as "Claim ID"
				Claim_Reference as "Claim Reference"
				Expense_Date as "Expense Date"
				department as "Department"
				client as "Client"
				category as "Category"
				amount_zar as "Amount ZAR"
				(
					display = total,average,min,max	
				)
				Supporting_Documents as "Supporting Documents"
				description as "Description"
				status as "Status"
				Rejection_Reason as "Rejection Reason"
				Version
				Parent_Claim_ID as "Parent Claim ID"
				gl_code as "GL Code"
				Department_Shadow as "Department Shadow"
			)
			group by
			(
				status ascending
				Department_Shadow ascending
				Employee_Name1 ascending
				category ascending
			)
			sort by
			(
				Submission_Date ascending
			)
			conditional formatting
			(
				"Pending LM Approval  dark magenta"
				{
				condition = (status == "Pending LM Approval")
				fields = [status]
				format = "text-decoration:line-through;color:#ffffff;background-color:#bd588b;"
				}
				"Pending HoD Approval dark teal"
				{
				condition = (Parent_Claim_ID.status == "Pending HoD Approval")
				fields = [status]
				format = "color:#ffffff;background-color:#107c91;"
				}
			)
		}
		list My_Claims
		{
			displayName = "My Claims"
			show all rows from expense_claims  [Added_User == zoho.loginuser]  
			(
				Employee_Name1  as "Employee Name"
	 			(
	      			displayformat = [first_name+""+prefix+""+last_name+""+suffix]
	 			)
				Email
				Submission_Date as "Submission Date"
				claim_id as "Claim ID"
				Claim_Reference as "Claim Reference"
				Expense_Date as "Expense Date"
				department as "Department"
				client as "Client"
				category as "Category"
				amount_zar as "Amount ZAR"
				Supporting_Documents as "Supporting Documents"
				description as "Description"
				status as "Status"
				Rejection_Reason as "Rejection Reason"
				Version
				Parent_Claim_ID as "Parent Claim ID"
				gl_code as "GL Code"
			)
			group by
			(
				claim_id ascending
				Expense_Date ascending
				Submission_Date descending
				category ascending
				amount_zar ascending
				status ascending
				Version ascending
			)
			sort by
			(
				Submission_Date descending
			)
			conditional formatting
			(
				"Approved/green"
				{
				condition = (status == "Approved")
				fields = [Employee_Name1, status]
				format = "color:#000000;background-color:#1bbc9b;"
				}
				"Rejected/red"
				{
				condition = (status == "Rejected")
				fields = [Employee_Name1, status]
				format = "color:#ffffff;background-color:#e84c3d;"
				}
				"LM Pending/amber"
				{
				condition = (status == "Pending LM Approval")
				fields = [Employee_Name1, status]
				format = "color:#333;background-color:#f1c40f;"
				}
				"HoD Pending/amber"
				{
				condition = (status == "Pending HoD Approval")
				fields = [Employee_Name1, status]
				format = "font-weight:bold;color:#333;background-color:#f1c40f;"
				}
				"Resubmitted/blue"
				{
				condition = (status == "Resubmitted")
				fields = [Employee_Name1, status]
				format = "color:#ffffff;background-color:#107c91;"
				}
			)
		}
		pivottable Expense_Summary
		{ 
			displayname = "Expense Summary"
			layout = 4
			report properties
			(
				records displayed = all_records
				allow export = false
				allow drilldown and view underlying data = false
		
			)

			based on Autoview_1775232194200_expense_claims
				show all rows from expense_claims
				(
			Email 
			Submission_Date  as "Submission Date"
			claim_id  as "Claim ID"
			Parent_Claim_ID.Department_Shadow  as "Department Shadow"
			Client_Shadow  as "Client Shadow"
			category  as "Category"
			amount_zar  as "Amount ZAR"
			status  as "Status"
				)
		}
	}
