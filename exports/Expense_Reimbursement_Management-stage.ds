		page Employee_Dashboard
		{
			displayname = "Employee Dashboard"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\twebDeviceConfig='{\"layout\":{\"displayType\":\"card\",\"design\":\"fluid\",\"style\":\"padding-right:0px;padding-top:0px;padding-bottom:0px;padding-left:0px;\"}}'\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width='100%'\n   \t>\n\t<dspZml id='zml_snippet1' elementName='My Expense Dashboard'\n>\n\t<![CDATA[htmlpage zml_snippet1()\ncontent\n&lt;%{\n\t%&gt;\n&lt;panel elementName=&apos;Header_Panel&apos;&gt;\n&lt;pr width=&apos;fill&apos; height=&apos;fill&apos;&gt;\n&lt;pc\n\tpadding = &apos;24px&apos;\n\tbgColor = &apos;#5A3D9B&apos;\n\twidth = &apos;100%&apos;\n\thAlign = &apos;left&apos;\n\tvAlign = &apos;middle&apos;\n&gt;\n&lt;pr width=&apos;auto&apos; height=&apos;auto&apos;&gt;\n&lt;pc\n\twidth = &apos;55%&apos;\n\thAlign = &apos;left&apos;\n\tvAlign = &apos;middle&apos;\n&gt;\n&lt;pr&gt;\n&lt;pc&gt;\n&lt;text\n\tcolor = &apos;#FFFFFF&apos;\n\tsize = &apos;26px&apos;\n\tbold = &apos;true&apos;\n\ttype = &apos;Text&apos;\n\tvalue = &apos;My Expense Dashboard&apos;\n&gt;\n&lt;/text&gt;\n&lt;/pc&gt;\n&lt;/pr&gt;\n&lt;pr&gt;\n&lt;pc&gt;\n&lt;text\n\tmarginTop = &apos;5px&apos;\n\tcolor = &apos;#E0D4F5&apos;\n\tsize = &apos;14px&apos;\n\ttype = &apos;Text&apos;\n\tvalue = &apos;Submit, track and manage your expense claims&apos;\n&gt;\n&lt;/text&gt;\n&lt;/pc&gt;\n&lt;/pr&gt;\n&lt;/pc&gt;\n&lt;pc\n\tpaddingTop = &apos;10px&apos;\n\tpaddingBottom = &apos;10px&apos;\n\tpaddingLeft = &apos;24px&apos;\n\tpaddingRight = &apos;24px&apos;\n\tbgColor = &apos;#0F6E56&apos;\n\thAlign = &apos;center&apos;\n\tvAlign = &apos;middle&apos;\n&gt;\n&lt;pr&gt;\n&lt;pc\n\thAlign = &apos;center&apos;\n&gt;\n&lt;text\n\taction = &apos;OpenForm&apos;\n\tcomponentLinkName = &apos;expense_claims&apos;\n\ttarget = &apos;same-window&apos;\n\tcolor = &apos;#FFFFFF&apos;\n\tsize = &apos;15px&apos;\n\tbold = &apos;true&apos;\n\ttype = &apos;Text&apos;\n\tvalue = &apos;Submit new claim&apos;\n&gt;\n&lt;/text&gt;\n&lt;/pc&gt;\n&lt;/pr&gt;\n&lt;/pc&gt;\n&lt;/pr&gt;\n&lt;/pc&gt;\n&lt;/pr&gt;\n&lt;/panel&gt;\n&lt;%\n\n}%&gt;]]>\n</dspZml>\n</column>\n</row><row>\n\t<column\n   \t\t width='100%'\n   \t>\n\t<dspZml id='zml_snippet' elementName='KPI tiles'\n>\n\t<![CDATA[htmlpage zml_snippet()\ncontent\n&lt;%{\n\t%&gt;\n&lt;panel elementName=&apos;KPI_Tiles&apos;\n\n\ttitle = &apos;Key Metrics&apos;\n\n\t\ttitleSize = &apos;15px&apos;\n&gt;\n&lt;pr width=&apos;fill&apos; height=&apos;fill&apos;&gt;\n&lt;pc\n\tpaddingTop = &apos;10px&apos;\n\tpaddingLeft = &apos;0px&apos;\n\tpaddingRight = &apos;0px&apos;\n\tpaddingBottom = &apos;0px&apos;\n\tbgColor = &apos;#FFFFFF&apos;\n\twidth = &apos;100%&apos;\n\thAlign = &apos;left&apos;\n\tvAlign = &apos;middle&apos;\n&gt;\n&lt;pr width=&apos;fill&apos; height=&apos;fill&apos;&gt;\n\n&lt;pc\n\tpadding = &apos;20px&apos;\n\tbgColor = &apos;#0F6E56&apos;\n\twidth = &apos;32%&apos;\n\thAlign = &apos;left&apos;\n\tvAlign = &apos;middle&apos;\n&gt;\n&lt;pr width=&apos;auto&apos; height=&apos;auto&apos;&gt;\n&lt;pc&gt;\n&lt;image\n\tmarginLeft = &apos;0px&apos;\n\tmarginBottom = &apos;0px&apos;\n\tmarginTop = &apos;0px&apos;\n\tcolor = &apos;#FFFFFF&apos;\n\tbgColor = &apos;#1ABE75&apos;\n\twidth = &apos;52px&apos;\n\theight = &apos;52px&apos;\n\ttype = &apos;icon&apos;\n\tvalue = &apos;business-percentage-39&apos;\n\tsize = &apos;20px&apos;\n\tcornerRadius = &apos;10px&apos;\n\ticonType = &apos;outline&apos;\n/&gt;\n&lt;/pc&gt;\n&lt;pc\n\thAlign = &apos;left&apos;\n&gt;\n&lt;pr&gt;\n&lt;pc&gt;\n&lt;text\n\tmarginLeft = &apos;20px&apos;\n\tcolor = &apos;#FFFFFF&apos;\n\tsize = &apos;22px&apos;\n\tbold = &apos;true&apos;\n\ttype = &apos;Form Data&apos;\n\tdisplayType = &apos;actual&apos;\n\tdecimalPlaces = &apos;2&apos;\n\tthousandsSeperator = &apos;LOCALE&apos;\n\tdecimalSeperator = &apos;DOT&apos;\n\tnumberScale = &apos;none&apos;\n\tcriteria = &apos;status == &amp;quot;Approved&amp;quot;&apos;\n\tvalue = &apos;thisapp.expense_claims.amount_zar.sum&apos;\n&gt;\n&lt;/text&gt;\n&lt;/pc&gt;\n&lt;/pr&gt;\n&lt;pr&gt;\n&lt;pc&gt;\n&lt;text\n\tmarginLeft = &apos;20px&apos;\n\tmarginRight = &apos;0px&apos;\n\tmarginTop = &apos;3px&apos;\n\tcolor = &apos;#E1F5EE&apos;\n\tsize = &apos;14px&apos;\n\ttype = &apos;Text&apos;\n\tvalue = &apos;Approved (ZAR)&apos;\n&gt;\n&lt;/text&gt;\n&lt;/pc&gt;\n&lt;/pr&gt;\n&lt;/pc&gt;\n&lt;/pr&gt;\n&lt;/pc&gt;\n\n&lt;pc\n\tpadding = &apos;20px&apos;\n\tbgColor = &apos;#3C3489&apos;\n\twidth = &apos;34%&apos;\n\thAlign = &apos;center&apos;\n&gt;\n&lt;pr width=&apos;auto&apos; height=&apos;auto&apos;&gt;\n&lt;pc&gt;\n&lt;image\n\tmarginLeft = &apos;0px&apos;\n\tmarginBottom = &apos;0px&apos;\n\tmarginTop = &apos;0px&apos;\n\tcolor = &apos;#FFFFFF&apos;\n\tbgColor = &apos;#734AD0&apos;\n\twidth = &apos;52px&apos;\n\theight = &apos;52px&apos;\n\ttype = &apos;icon&apos;\n\tvalue = &apos;education-paper&apos;\n\tsize = &apos;20px&apos;\n\tcornerRadius = &apos;10px&apos;\n\ticonType = &apos;outline&apos;\n/&gt;\n&lt;/pc&gt;\n&lt;pc\n\thAlign = &apos;left&apos;\n&gt;\n&lt;pr&gt;\n&lt;pc&gt;\n&lt;text\n\tmarginLeft = &apos;20px&apos;\n\tcolor = &apos;#FFFFFF&apos;\n\tsize = &apos;22px&apos;\n\tbold = &apos;true&apos;\n\ttype = &apos;Form Data&apos;\n\tdisplayType = &apos;actual&apos;\n\tthousandsSeperator = &apos;LOCALE&apos;\n\tdecimalSeperator = &apos;DOT&apos;\n\tnumberScale = &apos;none&apos;\n\tvalue = &apos;thisapp.expense_claims.ID.count&apos;\n&gt;\n&lt;/text&gt;\n&lt;/pc&gt;\n&lt;/pr&gt;\n&lt;pr&gt;\n&lt;pc&gt;\n&lt;text\n\tmarginLeft = &apos;20px&apos;\n\tmarginRight = &apos;0px&apos;\n\tmarginTop = &apos;3px&apos;\n\tcolor = &apos;#CECBF6&apos;\n\tsize = &apos;14px&apos;\n\ttype = &apos;Text&apos;\n\tvalue = &apos;Total Claims&apos;\n&gt;\n&lt;/text&gt;\n&lt;/pc&gt;\n&lt;/pr&gt;\n&lt;/pc&gt;\n&lt;/pr&gt;\n&lt;/pc&gt;\n\n&lt;pc\n\tpadding = &apos;20px&apos;\n\tbgColor = &apos;#854F0B&apos;\n\twidth = &apos;34%&apos;\n\thAlign = &apos;center&apos;\n&gt;\n&lt;pr width=&apos;auto&apos; height=&apos;auto&apos;&gt;\n&lt;pc&gt;\n&lt;image\n\tmarginLeft = &apos;0px&apos;\n\tmarginBottom = &apos;0px&apos;\n\tmarginTop = &apos;0px&apos;\n\tcolor = &apos;#FFFFFF&apos;\n\tbgColor = &apos;#F6BC2B&apos;\n\twidth = &apos;52px&apos;\n\theight = &apos;52px&apos;\n\ttype = &apos;icon&apos;\n\tvalue = &apos;design-todo&apos;\n\tsize = &apos;22px&apos;\n\tcornerRadius = &apos;10px&apos;\n\ticonType = &apos;outline&apos;\n/&gt;\n&lt;/pc&gt;\n&lt;pc\n\thAlign = &apos;left&apos;\n&gt;\n&lt;pr&gt;\n&lt;pc&gt;\n&lt;text\n\tmarginLeft = &apos;20px&apos;\n\tcolor = &apos;#FFFFFF&apos;\n\tsize = &apos;22px&apos;\n\tbold = &apos;true&apos;\n\ttype = &apos;Form Data&apos;\n\tdisplayType = &apos;actual&apos;\n\tthousandsSeperator = &apos;LOCALE&apos;\n\tdecimalSeperator = &apos;DOT&apos;\n\tnumberScale = &apos;none&apos;\n\tcriteria = &apos;status == &amp;quot;Pending LM Approval&amp;quot; || status == &amp;quot;Pending HoD Approval&amp;quot;&apos;\n\tvalue = &apos;thisapp.expense_claims.ID.count&apos;\n&gt;\n&lt;/text&gt;\n&lt;/pc&gt;\n&lt;/pr&gt;\n&lt;pr&gt;\n&lt;pc&gt;\n&lt;text\n\tmarginLeft = &apos;20px&apos;\n\tmarginRight = &apos;0px&apos;\n\tmarginTop = &apos;3px&apos;\n\tcolor = &apos;#FAEEDA&apos;\n\tsize = &apos;14px&apos;\n\ttype = &apos;Text&apos;\n\tvalue = &apos;Pending Approval&apos;\n&gt;\n&lt;/text&gt;\n&lt;/pc&gt;\n&lt;/pr&gt;\n&lt;/pc&gt;\n&lt;/pr&gt;\n&lt;/pc&gt;\n\n&lt;/pr&gt;\n&lt;/pc&gt;\n&lt;/pr&gt;\n&lt;/panel&gt;\n&lt;%\n\n}%&gt;]]>\n</dspZml>\n</column>\n</row><row>\n\t<column\n   \t\t width='100%'\n   \t>\n\t<report \n\telementName='Report'\n\n\t\tappLinkName = 'thisapp'\n\t\tlinkName = 'expense_claims_Report'\n\t\n\t\tiszreport = 'false'\n\t\t\t\t\tzc_AddRec = 'false'\n\t\t\t\t\tzc_EditRec = 'false'\n\t\t\t\t\tzc_Print = 'false'\n\t\t\t\t\tzc_DelRec = 'false'\n\t\t\t\t\tzc_DuplRec = 'false'\n\t\t\t\t\tzc_EditBulkRec = 'false'\n\t\t\t\t\tzc_BulkDelete = 'false'\n\t\t\t\t\tzc_BulkDuplicate = 'false'\n\theightType = 'custom'\n\theightValue = '500'\n\n/>\n</column>\n</row>\n</layout>\n</zml>"
		}
		page Management_Dashboard
		{
			displayname = "Management Dashboard"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width='100%'\n   \t>\n\t<report \n\telementName='Report'\n\n\t\tappLinkName = 'thisapp'\n\t\tlinkName = 'pending_approvals_manager'\n\t\n\t\tiszreport = 'false'\n\theightType = 'auto'\n\theightValue = '700'\n\n/>\n</column>\n</row><row>\n\t<column\n   \t\t width='100%'\n   \t>\n\t<report \n\telementName='Report 1'\n\n\t\tappLinkName = 'thisapp'\n\t\tlinkName = 'Expense_Summary'\n\t\n\t\tiszreport = 'true'\n\theightType = 'auto'\n\theightValue = '700'\n\n/>\n</column>\n</row>\n</layout>\n</zml>"
		}
	}


		workflow
		{
		form
		{
			Generate_Claim_Reference as "Generate Claim Reference"
			{
				type =  form
				form = expense_claims

				record event = on add

				on success
				{
					actions 
					{
						custom deluge script
						(
											num = input.claim_id.toString();
										padded = ("0000" + num).right(4);
										claim_reference = "EXP-" + padded;
						)
					}
				}

			}
			Resubmission_Handler as "Resubmission Handler"
			{
				type =  form
				form = expense_claims

				record event = on edit

				on update of Version
				{
					actions 
					{
						custom deluge script
						(
											if(input.status == "Resubmitted")
										{
											input.Version = input.Version + 1;
											input.Submission_Date = zoho.currenttime;
											// Determine routing
											isLM = thisapp.permissions.isUserInRole("Line Manager");
											if(isLM)
											{
												input.status = "Pending HoD Approval";
												approverEmail = "hod.demo@yourdomain.com";
											}
											else
											{
												input.status = "Pending LM Approval";
												approverEmail = "linemanager.demo@yourdomain.com";
											}
											// Audit trail
											row = insert into approval_history
											[
												claim=input.ID
												action_1="Resubmitted"
												actor=zoho.loginuser
												timestamp=zoho.currenttime
												comments="Resubmitted as version " + input.Version
												Added_User=zoho.loginuser
											];
											// Notify approver
											sendmail
											[
												from :zoho.adminuserid
												to :approverEmail
												subject :"RESUBMITTED - Claim " + input.claim_id + " (v" + input.Version + ")"
												message :"Edited and resubmitted for approval."
											]
										}
						)
					}
				}

			}
			Employee_Name_auto_popula as "Employee Name auto-population"
			{
				type =  form
				form = expense_claims

				record event = on add

				on load
				{
					actions 
					{
						custom deluge script
						(
											Employee_Name = zoho.loginuser;
										input.Email = zoho.loginuserid;
						)
					}
				}

			}
			Self_approval_prevention_ as "Self-approval prevention + routing + Audit trail"
			{
				type =  form
				form = expense_claims

				record event = on add

				on success
				{
					actions 
					{
						custom deluge script
						(
											// Self-approval prevention + audit trail
										// STEP 1: Self-Approval Prevention (King IV Principle 1)
										submitter = zoho.loginuser;
										if(thisapp.permissions.isUserInRole("Line Manager"))
										{
											input.status = "Pending HoD Approval";
											row = insert into approval_history
											[
												claim=input.ID
												action_1="Submitted (Self-approval bypass)"
												actor=submitter
												timestamp=zoho.currenttime
												comments="Submitter is a Line Manager. Routed directly to HoD."
												Added_User=zoho.loginuser
											];
											sendmail
											[
												from :zoho.adminuserid
												to :"hod.demo@yourdomain.com"
												subject :"Expense Claim " + input.claim_id + " — Direct HoD Review"
												message :"Submitted by LM. Self-approval prevention engaged."
											]
											return;
										}
										// Step 2: Audit Trail
										row = insert into approval_history
										[
											claim=input.ID
											action_1="Submitted"
											actor=zoho.loginuser
											timestamp=zoho.currenttime
											comments="Initial submission. Amount: R" + input.amount_zar
											Added_User=zoho.loginuser
										];
										// STEP 3: Notify LM
										sendmail
										[
											from :zoho.adminuserid
											to :"linemanager.demo@yourdomain.com"
											subject :"Expense Claim " + input.claim_id + " requires your approval"
											message :"Employee: " + input.Employee_Name1 + "\nAmount: R" + input.amount_zar
										]
						)
					}
				}

			}
			On_Validate_hard_stops_ as "On Validate (hard stops)"
			{
				type =  form
				form = expense_claims

				record event = on add or edit

				on validate
				{
					actions 
					{
						custom deluge script
						(
											// ON VALIDATE — Expense_Claims Form
										// SARS S11(a) substantiation + policy enforcement
										// 1. No future expense dates
										if(input.Expense_Date > zoho.currentdate)
										{
											alert "Expense date cannot be in the future.";
											cancel submit;
										}
										// 2. 90-day late submission policy
										daysDiff = daysBetween(input.Expense_Date,zoho.currentdate);
										if(daysDiff > 90)
										{
											alert "Expenses older than 90 days cannot be submitted. Contact Finance for exceptions.";
											cancel submit;
										}
										// 3. Positive amount
										if(input.amount_zar <= 0)
										{
											alert "Amount must be greater than zero.";
											cancel submit;
										}
										// 4. Mandatory receipt (SARS substantiation)
										if(input.Supporting_Documents == null || input.Supporting_Documents == "")
										{
											alert "At least one supporting document (receipt/invoice) is required.";
											cancel submit;
										}
										// 5. Duplicate claim detection (COSO fraud risk)
										duplicates = expense_claims[Expense_Date == input.Expense_Date && amount_zar == input.amount_zar && Added_User == zoho.loginuser && ID != input.ID];
										if(duplicates != null && duplicates.count() > 0)
										{
											alert "Potential duplicate claim detected: same date, amount, and submitter already exists. Please verify this is not a duplicate.";
										}
										// 6. VAT invoice type enforcement (SARS)
										if(input.amount_zar >= 5000 && input.VAT_Invoice_Type != "Full Tax Invoice (>= R5,000)")
										{
											alert "Claims of R5,000 or more require a Full Tax Invoice. Please update the VAT Invoice Type.";
											cancel submit;
										}
										// 7. POPIA consent (mandatory)
										if(input.POPIA_Consent == false)
										{
											alert "You must provide POPIA consent before submitting an expense claim.";
											cancel submit;
										}
										// 8. All validations pass
										input.status = "Submitted";
										input.Submission_Date = zoho.currenttime;
										input.Retention_Expiry_Date = input.Submission_Date.addYear(5);
						)
					}
				}

			}
			Fill_Shadow_text_fields as "Fill Shadow text fields"
			{
				type =  form
				form = expense_claims

				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											input.Department_Shadow = ifnull(input.department.name,"");
										input.Client_Shadow = ifnull(input.client.name,"");
						)
					}
				}

			}
		}

		schedule
		{
			SLA_Enforcement_Daily as "SLA Enforcement Daily"
			{
				type =  schedule
				form = expense_claims
				start = Submission_Date
				time zone = "Africa/Johannesburg"
				on start
				{
					actions 
					{
					on load
					(
						// SCHEDULED WORKFLOW: SLA Enforcement (runs daily)
										pendingClaims = expense_claims[status == "Pending LM Approval"];
										for each  claim in pendingClaims
										{
											daysSince = daysBetween(claim.Submission_Date,zoho.currentdate);
											if(daysSince >= 2)
											{
												// 2+ days — escalate
												claim.status="Pending HoD Approval";
												row = insert into approval_history
												[
													claim=claim.ID
													action_1="Escalated (SLA Breach)"
													actor="SYSTEM"
													timestamp=zoho.currenttime
													comments="LM did not act within 2 business days."
													Added_User=zoho.adminuser
												];
												sendmail
												[
													from :zoho.adminuserid
													to :"hod.demo@yourdomain.com"
													subject :"SLA BREACH - Claim " + claim.claim_id + " escalated"
													message :"LM failed to act within 2 days."
												]
											}
											else if(daysSince >= 1)
											{
												// 1 day — reminder
												sendmail
												[
													from :zoho.adminuserid
													to :"linemanager.demo@yourdomain.com"
													subject :"REMINDER - Claim " + claim.claim_id + " awaiting approval"
													message :"Pending >1 day. Auto-escalates at 2 days."
												]
											}
										}
					)
					}
				}
			}
		}

		approval
		{
			Line_Manager_Approval as "Line Manager Approval"
			{
				type =  approval
				form = expense_claims[status == "Pending LM Approval"]
				display fields = [Employee_Name1,Email,Submission_Date,claim_id,Claim_Reference,Expense_Date,department]
				on start
				{
				}
				on level 1
				{
					approvers
					(
			 			role = "Line Manager"
					)
					on approve 
					{
						actions  (status == "Pending LM Approval")
						{
						on load
						(
							// Purpose: Threshold-based conditional routing.
												//   Under threshold = final approval + GL code population.
												//   Over threshold = escalate to HoD.
												// Query threshold config table
												thresholdRec = approval_thresholds[tier_name == "Tier 1 \u2013 Line Manager" && Active == true];
												// Null guard: if config record missing, use fallback matching seed data
												if(thresholdRec != null)
												{
													thresholdAmount = ifnull(thresholdRec.max_amount_zar,999.99);
												}
												else
												{
													thresholdAmount = 999.99;
													row = insert into approval_history
													[
														claim=input.ID
														action_1="Warning"
														actor=zoho.loginuser
														timestamp=zoho.currenttime
														comments="Approval threshold config record not found. Using fallback R999.99."
														Added_User=zoho.loginuser
													];
												}
												if(input.amount_zar <= thresholdAmount)
												{
													// Under threshold — LM gives final approval
													input.status = "Approved";
													// GL code auto-population
													glCode = "";
													glRec = gl_accounts[expense_category == input.category && Active == true];
													if(glRec != null && glRec.count() > 0)
													{
														input.gl_code = glRec.gl_code;
													}
													row = insert into approval_history
													[
														claim=input.ID
														action_1="Approved (LM)"
														actor=zoho.loginuser
														timestamp=zoho.currenttime
														comments="Line Manager final approval. GL: " + ifnull(glCode,"UNMAPPED")
														Added_User=zoho.loginuser
													];
													sendmail
													[
														from :zoho.adminuserid
														to :input.Email
														subject :"Expense Claim " + input.claim_id + " \u2014 Approved"
														message :"Your claim for R" + input.amount_zar + " has been approved."
													]
												}
												else
												{
													// Over threshold — escalate to HoD
													input.status = "Pending HoD Approval";
													row = insert into approval_history
													[
														claim=input.ID
														action_1="Approved (LM)"
														actor=zoho.loginuser
														timestamp=zoho.currenttime
														comments="LM approved. Amount R" + input.amount_zar + " exceeds tier 1 threshold (R" + thresholdAmount + ") \u2014 escalated to HoD."
														Added_User=zoho.loginuser
													];
													sendmail
													[
														from :zoho.adminuserid
														to :"hod.demo@yourdomain.com"
														subject :"Expense Claim " + input.claim_id + " \u2014 Requires HoD Approval"
														message :"LM approved. Amount R" + input.amount_zar + " exceeds threshold. Awaiting HoD review."
													]
												}
						)
						}
					}
					on reject
					{

						actions 
						{
						on load
						(
							// Purpose: Set status to Rejected, log audit trail, notify employee.
												input.status = "Rejected";
												// Capture rejection reason — ifnull guard for empty textarea
												rejectReason = ifnull(input.Rejection_Reason,"No reason provided");
												row = insert into approval_history
												[
													claim=input.ID
													action_1="Rejected"
													actor=zoho.loginuser
													timestamp=zoho.currenttime
													comments=rejectReason
													Added_User=zoho.loginuser
												];
												sendmail
												[
													from :zoho.adminuserid
													to :input.Email
													subject :"Expense Claim " + input.claim_id + " \u2014 Rejected"
													message :"Your claim for R" + input.amount_zar + " has been rejected.\nReason: " + rejectReason + "\nYou may edit and resubmit."
												]
						)
						}
					}
				}
				on level 2
				{
					approvers
					(
			 			role = "HoD"
					)
					on approve 
					{
						actions  (status == "Pending HoD Approval")
						{
						on load
						(
							// Purpose: Final approval, GL code population, audit trail, notification.
												input.status = "Approved";
												// GL code auto-population (same pattern as LM final approval)
												glCode = "";
												glRec = gl_accounts[expense_category == input.category && Active == true];
												if(glRec != null && glRec.count() > 0)
												{
													input.gl_code = glRec.gl_code;
												}
												row = insert into approval_history
												[
													claim=input.ID
													action_1="Approved (HoD)"
													actor=zoho.loginuser
													timestamp=zoho.currenttime
													comments="Head of Department final approval. GL: " + ifnull(glCode,"UNMAPPED")
													Added_User=zoho.loginuser
												];
												sendmail
												[
													from :zoho.adminuserid
													to :input.Email
													subject :"Expense Claim " + input.claim_id + " \u2014 Final Approval"
													message :"Your claim for R" + input.amount_zar + " has received final approval."
												]
						)
						}
					}
					on reject
					{

						actions  (status == "Pending HoD Approval")
						{
						on load
						(
							// Purpose: Set status to Rejected, log audit trail, notify employee.
												input.status = "Rejected";
												rejectReason = ifnull(input.Rejection_Reason,"No reason provided");
												row = insert into approval_history
												[
													claim=input.ID
													action_1="Rejected"
													actor=zoho.loginuser
													timestamp=zoho.currenttime
													comments="HoD rejection. Reason: " + rejectReason
													Added_User=zoho.loginuser
												];
												sendmail
												[
													from :zoho.adminuserid
													to :input.Email
													subject :"Expense Claim " + input.claim_id + " \u2014 Rejected by HoD"
													message :"Your claim for R" + input.amount_zar + " has been rejected by the Head of Department.\nReason: " + rejectReason + "\nYou may edit and resubmit."
												]
						)
						}
					}
				}
			}
		}



	}
